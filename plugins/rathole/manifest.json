{
  "schema": 5,
  "id": "rathole",
  "name": "Rathole",
  "description": "通过安全隧道远程访问 GX 设备和同一局域网内的服务。",
  "version": "0.2.1",
  "runtime": {
    "kind": "native-service",
    "executable": "bin/venus-rathole",
    "companion_executables": ["bin/rathole"]
  },
  "settings": {
    "enabled_path": "/Settings/Plugins/rathole/Enabled"
  },
  "ui": {
    "settings_page": "qml/PageRatholeSettings.qml",
    "device_list": {
      "value_paths": [
        "com.victronenergy.rathole/Status/State"
      ]
    }
  }
}
